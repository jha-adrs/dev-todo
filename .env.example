# Required (auto-generated by setup.sh if not provided)
JWT_SECRET=changeme-generate-a-real-secret
PORT=3000

# Database (optional — defaults to local SQLite file)
DB_PROVIDER=sqlite
DB_PATH=./data/devtodo.db

# For Turso cloud (set DB_PROVIDER=turso):
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-token

# Image storage (optional — defaults to local)
STORAGE_PROVIDER=local

# Logging
LOG_LEVEL=info

# CORS (comma-separated origins, or * for all)
ALLOWED_ORIGINS=*

# For S3/R2 (set STORAGE_PROVIDER=s3):
# S3_BUCKET=your-bucket
# S3_REGION=auto
# S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
# S3_ACCESS_KEY_ID=xxx
# S3_SECRET_ACCESS_KEY=xxx
